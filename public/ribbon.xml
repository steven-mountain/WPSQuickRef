<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="ribbon.OnAddinLoad">
  <ribbon startFromScratch="false">
    <tabs>
      <tab id="quickRefTab" label="引用助手">
        <group id="quickRefGroup" label="书签页码交叉引用">
          <button id="btnCreateRefSource" label="创建引用源" onAction="ribbon.OnAction" getEnabled="ribbon.OnGetEnabled" getImage="ribbon.GetImage" visible="true" size="large"/>
          <button id="btnInsertPageRef" label="插入页码引用" onAction="ribbon.OnAction" getEnabled="ribbon.OnGetEnabled" getImage="ribbon.GetImage" visible="true" size="large"/>
          <button id="btnRefManager" label="引用源管理" onAction="ribbon.OnAction" getEnabled="ribbon.OnGetEnabled" getImage="ribbon.GetImage" visible="true" size="large"/>
          <button id="btnUpdateAllRefs" label="更新全部引用" onAction="ribbon.OnAction" getEnabled="ribbon.OnGetEnabled" getImage="ribbon.GetImage" visible="true" size="large"/>
          <button id="btnCheckInvalidRefs" label="检查失效引用" onAction="ribbon.OnAction" getEnabled="ribbon.OnGetEnabled" getImage="ribbon.GetImage" visible="true" size="large"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
